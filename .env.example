# Local Postgres connection string used by Prisma and API functions.
# Docker local default: user=postgres password=postgres db=todo port=5432.
# For Vercel Postgres, you can copy POSTGRES_URL from the Vercel dashboard.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/todo?schema=public"

# Optional override for frontend when API is hosted in another origin.
# In local development this is not required because Vite proxy is not needed for /api.
VITE_API_BASE_URL="/api"
